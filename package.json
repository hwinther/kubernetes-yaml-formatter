{
  "name": "yet-another-better-yaml-formatter",
  "displayName": "(yet another) Better YAML Formatter",
  "icon": "images/icon.png",
  "description": "A (yet another) better YAML formatter",
  "version": "0.1.0",
  "publisher": "hwinther",
  "repository": {
    "url": "https://github.com/hwinther/kubernetes-yaml-formatter.git",
    "type": "git"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "homepage": "https://github.com/hwinther/kubernetes-yaml-formatter",
  "badges": [
    {
      "description": "Github Actions",
      "href": "https://github.com/hwinther/kubernetes-yaml-formatter",
      "url": "https://github.com/hwinther/kubernetes-yaml-formatter/actions/workflows/release.yaml/badge.svg"
    }
  ],
  "author": {
    "email": "hwinther@wsh.no",
    "name": "Hans Christian Winther-Sørensen"
  },
  "keywords": [
    "YAML",
    "CI/CD",
    "DevOps",
    "Formatter",
    "Kubernetes",
    "GitHub Actions"
  ],
  "bugs": {
    "url": "https://github.com/hwinther/kubernetes-yaml-formatter/issues"
  },
  "categories": [
    "Formatters"
  ],
  "engines": {
    "vscode": "^1.63.0"
  },
  "activationEvents": [
    "onLanguage:yaml",
    "onLanguage:helm",
    "onLanguage:ansible",
    "onLanguage:github-actions-workflow"
  ],
  "main": "./out/extension.js",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "configuration": {
      "title": "Better YAML",
      "properties": {
        "better-yaml.indentSeq": {
          "type": "boolean",
          "default": false,
          "description": "Whether block sequences should be indented."
        },
        "better-yaml.directives": {
          "type": [
            "boolean",
            "null"
          ],
          "default": null,
          "description": "Include directives in the output. If true, at least the document-start marker --- is always included. If false, no directives or marker is ever included. If null, directives and marker may be included if required."
        },
        "better-yaml.commentString": {
          "type": [
            "string",
            "null"
          ],
          "default": null,
          "description": "Output should be valid for the current schema. By default, empty comment lines are left empty, lines consisting of a single space are replaced by #, and all other lines are prefixed with a #."
        },
        "better-yaml.lineWidth": {
          "type": [
            "number"
          ],
          "default": 0,
          "description": "Maximum line width (set to 0 to disable folding). This is a soft limit, as only double-quoted semantics allow for inserting a line break in the middle of a word."
        },
        "better-yaml.flowCollectionPadding": {
          "type": [
            "boolean"
          ],
          "default": true,
          "description": "When true, a single space of padding will be added inside the delimiters of non-empty single-line flow collections."
        },
        "better-yaml.documentOptions.version": {
          "type": [
            "string"
          ],
          "default": "1.2",
          "description": "The YAML version used by documents without a %YAML directive. Must be '1.1' or '1.2'."
        }
      }
    },
    "configurationDefaults": {
      "[yaml]": {
        "editor.defaultFormatter": "hwinther.yet-another-better-yaml-formatter",
        "editor.formatOnSave": true
      },
      "[helm]": {
        "editor.defaultFormatter": "hwinther.yet-another-better-yaml-formatter",
        "editor.formatOnSave": false
      },
      "[ansible]": {
        "editor.defaultFormatter": "hwinther.yet-another-better-yaml-formatter",
        "editor.formatOnSave": false
      },
      "[github-actions-workflow]": {
        "editor.defaultFormatter": "hwinther.yet-another-better-yaml-formatter",
        "editor.formatOnSave": false
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run compile-web",
    "compile": "tsc -p ./",
    "compile-web": "webpack",
    "watch": "tsc -watch -p ./",
    "watch-web": "webpack --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test",
    "package-web": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "25.x",
    "@types/vscode": "^1.118.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.11.0",
    "@vscode/test-cli": "^0.0.9",
    "@vscode/test-electron": "^2.4.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.5",
    "ts-loader": "^9.5.1",
    "webpack": "^5.92.1",
    "webpack-cli": "^5.1.4",
    "@types/webpack-env": "^1.18.8",
    "assert": "^2.1.0",
    "process": "^0.11.10"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
